<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ru.gr0946x.ui.ChatController"
      prefWidth="800" prefHeight="500"
      style="-fx-background-color: #1e1e2e;">

    <!-- Левая панель: список пользователей -->
    <VBox prefWidth="200" style="-fx-background-color: #181825;">
        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

        <Label text="Онлайн" style="-fx-text-fill: #89b4fa; -fx-font-weight: bold; -fx-font-size: 13;"/>

        <ListView fx:id="userList" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #181825; -fx-border-color: transparent;"/>

        <Label text="📢 Написать всем" style="-fx-text-fill: #6c7086; -fx-font-size: 11;
               -fx-cursor: hand;" onMouseClicked="#onSelectBroadcast"/>
    </VBox>

    <!-- Правая панель: чат -->
    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #1e1e2e;">
        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

        <!-- Заголовок чата -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="chatWithLabel" text="Выберите собеседника"
                   style="-fx-text-fill: #cdd6f4; -fx-font-size: 14; -fx-font-weight: bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <!-- Поиск -->
            <TextField fx:id="searchField" promptText="🔍 Поиск..."
                       prefWidth="160"
                       style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;
                              -fx-prompt-text-fill: #6c7086; -fx-background-radius: 6;
                              -fx-padding: 5;"/>
            <Button text="Найти" onAction="#onSearch"
                    style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e;
                           -fx-background-radius: 6; -fx-padding: 5 10; -fx-cursor: hand;"/>
        </HBox>

        <!-- Область сообщений -->
        <ListView fx:id="messageList" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #1e1e2e; -fx-border-color: transparent;"/>

        <!-- Поле ввода -->
        <HBox spacing="8" alignment="CENTER">
            <TextField fx:id="inputField" promptText="Сообщение..."
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;
                              -fx-prompt-text-fill: #6c7086; -fx-background-radius: 6;
                              -fx-padding: 8;" onAction="#onSend"/>
            <Button text="➤" onAction="#onSend"
                    style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e;
                           -fx-font-size: 16; -fx-background-radius: 6;
                           -fx-padding: 6 14; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</HBox>