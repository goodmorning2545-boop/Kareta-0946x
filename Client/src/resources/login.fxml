<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ru.gr0946x.ui.LoginController"
      spacing="10" alignment="CENTER"
      prefWidth="350" prefHeight="300"
      style="-fx-background-color: #1e1e2e;">

    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

    <Label text="🪄 Карета" style="-fx-font-size: 24; -fx-text-fill: #cdd6f4; -fx-font-weight: bold;"/>
    <Label text="Мессенджер" style="-fx-font-size: 12; -fx-text-fill: #6c7086;"/>

    <Label fx:id="errorLabel" text=""
           style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" wrapText="true"/>

    <TextField fx:id="usernameField" promptText="Имя пользователя"
               style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;
                      -fx-prompt-text-fill: #6c7086; -fx-border-radius: 6;
                      -fx-background-radius: 6; -fx-padding: 8;"/>

    <PasswordField fx:id="passwordField" promptText="Пароль"
                   style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4;
                          -fx-prompt-text-fill: #6c7086; -fx-border-radius: 6;
                          -fx-background-radius: 6; -fx-padding: 8;"/>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="loginBtn" text="Войти" onAction="#onLogin"
                style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e;
                       -fx-font-weight: bold; -fx-background-radius: 6;
                       -fx-padding: 8 20; -fx-cursor: hand;"/>
        <Button fx:id="registerBtn" text="Регистрация" onAction="#onRegister"
                style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e;
                       -fx-font-weight: bold; -fx-background-radius: 6;
                       -fx-padding: 8 20; -fx-cursor: hand;"/>
    </HBox>
</VBox>